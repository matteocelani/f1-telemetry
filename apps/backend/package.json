{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev:replay": "ts-node -r tsconfig-paths/register src/replay.ts",
    "record": "node --max-old-space-size=8192 -r ts-node/register -r tsconfig-paths/register src/record.ts",
    "lint": "tsc --noEmit",
    "build": "tsc && tsc-alias"
  },
  "dependencies": {
    "@f1-telemetry/core": "workspace:*",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
