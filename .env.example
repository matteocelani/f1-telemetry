# Backend environment variables
# Copy this file to .env and fill in the values before running.

# Port for the WebSocket server and health check endpoint (default: 8080)
PORT=8080

# Frontend environment variables (optional — defaults are used if not set)

# Backend URL used by the frontend for health checks (default: http://localhost:8080)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket relay URL used by the frontend for live data (default: ws://localhost:8080/ws)
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
